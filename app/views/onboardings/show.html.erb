<%= content_for :prev_nav do %>
  <%= image_tag "logomark-color.svg", class: "w-10 h-10" %>
<% end %>

<%= content_for :header_nav do %>
  <%= render "onboardings/steps", current: 0 %>
<% end %>

<%= content_for :cancel_action do %>
  <%= render "onboardings/logout" %>
<% end %>

<div class="grow max-w-lg w-full mx-auto bg-surface flex flex-col justify-center md:py-0 py-2 px-4 md:px-0">
  <div>
    <div class="space-y-1 mb-8 text-center">
      <h1 class="text-2xl font-medium"><%= t(".title") %></h1>
      <p class="text-secondary text-sm"><%= t(".subtitle") %></p>
    </div>

    <div class="space-y-3 mb-8">
      <div class="flex items-start gap-3 bg-container rounded-xl shadow-border-xs p-4">
        <span class="mt-0.5"><%= icon("chart-line", size: "md", color: "success") %></span>
        <div>
          <p class="text-sm font-medium text-primary"><%= t(".outcome_pace_title") %></p>
          <p class="text-sm text-secondary"><%= t(".outcome_pace_body") %></p>
        </div>
      </div>
      <div class="flex items-start gap-3 bg-container rounded-xl shadow-border-xs p-4">
        <span class="mt-0.5"><%= icon("trending-up", size: "md", color: "success") %></span>
        <div>
          <p class="text-sm font-medium text-primary"><%= t(".outcome_net_worth_title") %></p>
          <p class="text-sm text-secondary"><%= t(".outcome_net_worth_body") %></p>
        </div>
      </div>
      <div class="flex items-start gap-3 bg-container rounded-xl shadow-border-xs p-4">
        <span class="mt-0.5"><%= icon("users-round", size: "md", color: "success") %></span>
        <div>
          <p class="text-sm font-medium text-primary"><%= t(".outcome_compare_title") %></p>
          <p class="text-sm text-secondary"><%= t(".outcome_compare_body") %></p>
        </div>
      </div>
    </div>

    <div class="flex items-start gap-3 rounded-xl border border-tertiary p-4 mb-8">
      <div class="w-8 h-8 shrink-0 rounded-full bg-surface-inset flex items-center justify-center text-xs font-medium text-primary">FL</div>
      <p class="text-sm text-secondary"><%= t(".founder_note") %> <span class="text-primary font-medium"><%= t(".founder_sig") %></span></p>
    </div>

    <%= render DS::Link.new(text: t(".cta"), variant: "primary", full_width: true, href: preferences_onboarding_path) %>
  </div>
</div>

<%= content_for :previous_path, onboarding_path %>

<%= content_for :header_nav do %>
  <%= render "onboardings/steps", current: 1 %>
<% end %>

<%= content_for :cancel_action do %>
  <%= render "onboardings/logout" %>
<% end %>

<div class="grow max-w-lg w-full mx-auto bg-surface flex flex-col justify-center md:py-0 py-6 px-4 md:px-0">
  <div>
    <div class="space-y-1 mb-6">
      <h1 class="text-2xl font-medium"><%= t(".title") %></h1>
      <p class="text-secondary text-sm"><%= t(".subtitle") %></p>
    </div>

    <%= form_with url: personalize_onboarding_path, method: :patch, scope: :onboarding do |f| %>
      <div class="bg-container rounded-xl shadow-border-xs p-4 mb-4">
        <p class="text-sm font-medium text-primary mb-3"><%= t(".goal_label") %></p>
        <div class="space-y-2">
          <% { "overspending" => [ t(".goal_overspending"), "chart-line" ],
               "grow_wealth" => [ t(".goal_grow_wealth"), "trending-up" ],
               "see_everything" => [ t(".goal_see_everything"), "layout-dashboard" ] }.each do |value, (label, icn)| %>
            <label class="flex items-center gap-3 rounded-lg border border-tertiary p-3 cursor-pointer hover:bg-container-inset has-[:checked]:border-primary has-[:checked]:bg-container-inset">
              <input type="radio" name="onboarding[goal]" value="<%= value %>" <%= "checked" if value == "see_everything" %> class="accent-current">
              <span class="flex items-center gap-2 text-sm text-primary"><%= icon(icn, size: "sm", color: "current") %><%= label %></span>
            </label>
          <% end %>
        </div>
        <p class="text-xs text-secondary mt-2"><%= t(".goal_hint") %></p>
      </div>

      <div class="bg-container rounded-xl shadow-border-xs p-4 mb-2">
        <p class="text-sm font-medium text-primary mb-1"><%= t(".cohort_label") %></p>
        <p class="text-xs text-secondary mb-3"><%= t(".cohort_privacy") %></p>
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="flex-1">
            <label class="text-xs text-secondary" for="onboarding_age_band"><%= t(".age_label") %></label>
            <select name="onboarding[age_band]" id="onboarding_age_band" class="form-field__input w-full">
              <option value=""><%= t(".age_prompt") %></option>
              <% { "under_25" => "Under 25", "25_34" => "25–34", "35_44" => "35–44", "45_54" => "45–54", "55_64" => "55–64", "65_plus" => "65+" }.each do |val, label| %>
                <option value="<%= val %>"><%= label %></option>
              <% end %>
            </select>
          </div>
          <div class="flex-1">
            <label class="text-xs text-secondary" for="onboarding_metro"><%= t(".metro_label") %></label>
            <select name="onboarding[metro]" id="onboarding_metro" class="form-field__input w-full">
              <%# Blank default: only an ACTIVE choice (incl. explicit national)
                  counts as answered — otherwise Continue would silently lock
                  the /compare cohort form away (review finding). %>
              <option value=""><%= t(".metro_prompt") %></option>
              <option value="__national__"><%= t(".metro_national") %></option>
              <% Cohort::METROS.keys.each do |m| %>
                <option value="<%= m %>"><%= m %></option>
              <% end %>
            </select>
          </div>
        </div>
      </div>

      <p class="text-xs text-subdued mb-6"><%= t(".unlock_hint") %></p>

      <div class="space-y-3">
        <%= render DS::Button.new(text: t(".continue"), variant: "primary", full_width: true, type: "submit") %>
        <button type="submit" name="skip" value="1" class="w-full text-sm text-secondary hover:text-primary underline bg-transparent border-0 cursor-pointer">
          <%= t(".skip") %>
        </button>
      </div>
    <% end %>
  </div>
</div>

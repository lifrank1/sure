<div class="space-y-4 pb-6 lg:pb-12 flex flex-col">
  <header class="flex justify-between items-center text-primary font-medium">
    <h1 class="text-xl"><%= t(".categories") %></h1>
    <div class="flex items-center gap-2">
      <%= render DS::Menu.new do |menu| %>
        <% menu.with_item(
            variant: "link",
            text: t(".merge"),
            href: merge_categories_path,
            frame: :modal,
            icon: "combine") %>
        <% menu.with_item(
            variant: "button",
            text: t(".delete_all"),
            href: destroy_all_categories_path,
            method: :delete,
            icon: "trash-2",
            confirm: CustomConfirm.for_resource_deletion("all categories", high_severity: true)) %>
      <% end %>

      <%= render DS::Link.new(
        text: t(".new"),
        variant: "primary",
        icon: "plus",
        href: new_category_path,
        frame: :modal
      ) %>
    </div>
  </header>

  <% if @categories.any? %>
    <%# Month header: spent vs budgeted %>
    <div class="bg-container rounded-xl shadow-border-xs p-4">
      <div class="flex items-center justify-around text-center">
        <div>
          <p class="text-2xl font-medium text-primary privacy-sensitive"><%= format_money(@total_spent) %></p>
          <p class="text-sm text-secondary">
            <%= t(".spent_in", month: Date.current.strftime("%B")) %><% if @total_invested.amount.positive? %> <span class="text-subdued privacy-sensitive">· <%= t(".plus_invested", invested: format_money(@total_invested)) %></span><% end %>
          </p>
        </div>
        <% if @total_budget %>
          <div>
            <p class="text-2xl font-medium text-primary privacy-sensitive"><%= format_money(@total_budget) %></p>
            <p class="text-sm text-secondary"><%= t(".total_budget") %></p>
          </div>
        <% else %>
          <div>
            <%= link_to t(".set_budget"), budgets_path, class: "text-sm text-link hover:underline", data: { turbo_frame: "_top" } %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Per-category spending (parents, children rolled up), Copilot-style bars %>
    <div class="bg-container rounded-xl shadow-border-xs p-4 space-y-1">
      <div class="flex items-center px-3 py-2 text-xs font-medium text-secondary uppercase">
        <p class="grow"><%= t(".category") %></p>
        <p class="w-24 text-right"><%= t(".spent") %></p>
        <div class="w-1/3 mx-4 hidden sm:block"></div>
        <p class="w-24 text-right"><%= @budget ? t(".budget") : t(".monthly_avg") %></p>
        <div class="w-8"></div>
      </div>

      <%
        overview_rows = @category_groups.map do |group|
          category = group.category
          spent = @spent_by_category[category.id].to_f
          budgeted = @budgeted_by_category[category.id]&.budgeted_spending.to_f
          avg = @budget ? 0 : @income_statement.avg_expense(category: category).to_f
          { category: category, spent: spent, budgeted: budgeted, avg: avg }
        end.sort_by { |row| -row[:spent] }
      %>

      <% overview_rows.each do |row| %>
        <% category = row[:category] %>
        <% category_color = category.color.presence || Category::UNCATEGORIZED_COLOR %>
        <% denominator = @budget ? row[:budgeted] : row[:avg] %>
        <% pct = denominator.positive? ? (row[:spent] / denominator * 100) : nil %>
        <% bar_color = if @budget && pct && pct >= 100
             "#e11d48"
           elsif @budget && pct && pct >= 80
             "#f59e0b"
           else
             category_color
           end %>
        <div class="flex items-center px-3 py-2 rounded-lg hover:bg-surface-hover group">
          <%= link_to transactions_path(q: { categories: [category.name], start_date: @period.date_range.first, end_date: @period.date_range.last }),
              class: "flex items-center gap-3 grow min-w-0",
              data: { turbo_frame: "_top" } do %>
            <div class="h-7 w-7 flex-shrink-0 rounded-full flex justify-center items-center"
              style="background-color: color-mix(in oklab, <%= category_color %> 10%, transparent); color: <%= category_color %>;">
              <% if category.lucide_icon.present? %>
                <%= icon(category.lucide_icon, color: "current", size: "sm") %>
              <% else %>
                <span class="text-xs font-medium"><%= category.name.first %></span>
              <% end %>
            </div>
            <span class="text-sm font-medium text-primary truncate"><%= category.name %></span>
          <% end %>

          <p class="w-24 text-right text-sm font-medium text-primary privacy-sensitive shrink-0">
            <%= format_money(Money.new(row[:spent], Current.family.currency)) %>
          </p>

          <div class="w-1/3 mx-4 hidden sm:block shrink-0">
            <% if pct %>
              <div class="h-1.5 bg-surface-inset rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="width: <%= [pct, 100].min.round(1) %>%; background-color: <%= bar_color %>;"></div>
              </div>
            <% end %>
          </div>

          <p class="w-24 text-right text-sm text-secondary privacy-sensitive shrink-0">
            <% if @budget %>
              <%= row[:budgeted].positive? ? format_money(Money.new(row[:budgeted], Current.family.currency)) : "–" %>
            <% else %>
              <%= row[:avg].positive? ? "~#{format_money(Money.new(row[:avg], Current.family.currency))}" : "–" %>
            <% end %>
          </p>

          <div class="w-8 flex justify-end shrink-0">
            <%= render DS::Link.new(
              variant: "icon",
              icon: "pencil-line",
              size: "sm",
              href: edit_category_path(category),
              frame: :modal,
              class: "opacity-0 group-hover:opacity-100 transition-opacity"
            ) %>
          </div>
        </div>
      <% end %>

      <% if @uncategorized_spent.positive? %>
        <%= link_to transactions_categorize_path,
            class: "flex items-center justify-between px-3 py-2 rounded-lg hover:bg-surface-hover text-sm",
            data: { turbo_frame: "_top" } do %>
          <span class="flex items-center gap-2 text-secondary">
            <%= icon("circle-dashed", size: "sm") %>
            <%= t(".uncategorized_cta") %>
          </span>
          <span class="font-medium text-primary privacy-sensitive"><%= format_money(Money.new(@uncategorized_spent, Current.family.currency)) %></span>
        <% end %>
      <% end %>
    </div>

    <%# Full management list (subcategories, merge targets) stays reachable %>
    <div class="bg-container rounded-xl shadow-border-xs p-4">
      <%= render DS::Disclosure.new(title: t(".manage_all"), align: :left) do %>
        <div class="space-y-4 pt-2">
          <%= render "categories/category_list_group",
                     title: t(".categories"),
                     categories: @categories,
                     category_groups: @category_groups,
                     category_ids_with_transactions: @category_ids_with_transactions %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-container rounded-xl shadow-border-xs p-4">
      <div class="flex justify-center items-center py-20">
        <div class="text-center flex flex-col items-center max-w-[500px]">
          <p class="text-sm text-secondary mb-4"><%= t(".empty") %></p>
          <div class="flex items-center gap-2">
            <%= render DS::Button.new(
              text: t(".bootstrap"),
              href: bootstrap_categories_path,
            ) %>

            <%= render DS::Link.new(
              text: t(".new"),
              variant: "outline",
              icon: "plus",
              href: new_category_path,
              frame: :modal
            ) %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%# locals: (steps:) %>
<% done_count = steps.count { |s| s[:done] } %>
<% pct = (done_count.to_f / steps.size * 100).round %>

<div class="mb-4 bg-container rounded-xl shadow-border-xs p-4 space-y-3">
  <div class="flex items-center justify-between gap-4">
    <h2 class="text-sm font-medium text-primary"><%= t("pages.dashboard.getting_started.title") %></h2>
    <div class="flex items-center gap-3 shrink-0">
      <span class="text-xs text-secondary"><%= t("pages.dashboard.getting_started.progress", pct: pct) %></span>
      <%= button_to dismiss_getting_started_path,
            method: :post,
            class: "text-secondary hover:text-primary",
            title: t("pages.dashboard.getting_started.dismiss"),
            aria: { label: t("pages.dashboard.getting_started.dismiss") } do %>
        <%= icon "x", size: "sm" %>
      <% end %>
    </div>
  </div>

  <div class="h-1.5 bg-container-inset rounded-full overflow-hidden">
    <div class="h-full bg-success rounded-full transition-all" style="width: <%= pct %>%"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2">
    <% steps.each do |step| %>
      <% row = capture do %>
        <span class="flex items-center gap-2 text-sm min-w-0">
          <% if step[:done] %>
            <%= icon "check-circle", size: "sm", class: "text-success shrink-0" %>
            <span class="text-secondary line-through truncate"><%= t("pages.dashboard.getting_started.steps.#{step[:key]}") %></span>
          <% else %>
            <%= icon "circle", size: "sm", class: "text-subdued shrink-0" %>
            <span class="text-primary font-medium truncate"><%= t("pages.dashboard.getting_started.steps.#{step[:key]}") %></span>
          <% end %>
        </span>
      <% end %>

      <% if step[:done] || step[:href].nil? %>
        <div class="px-3 py-2 rounded-lg bg-container-inset"><%= row %></div>
      <% else %>
        <%= link_to step[:href],
              class: "px-3 py-2 rounded-lg bg-container-inset hover:bg-surface-hover transition-colors",
              data: { turbo_frame: "_top" } do %>
          <%= row %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>

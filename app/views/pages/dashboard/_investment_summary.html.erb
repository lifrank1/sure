<%# locals: (investment_statement:, period:, **args) %>

<%# Compact portfolio summary — the /investments page owns the full detail
    (all holdings, chart, activity, gains by tax treatment) %>
<% if investment_statement.investment_accounts.any? %>
  <div id="investment-summary" class="space-y-4 px-4">
    <div class="space-y-2">
      <p class="text-primary text-3xl font-medium privacy-sensitive">
        <%= format_money(investment_statement.portfolio_value_money) %>
      </p>

      <% trend = investment_statement.unrealized_gains_trend %>
      <% if trend %>
        <div class="flex items-center gap-2 text-sm">
          <span class="text-secondary"><%= t(".total_return") %>:</span>
          <span class="font-medium privacy-sensitive" style="color: <%= trend.color %>">
            <%= format_money(Money.new(trend.value, Current.family.currency)) %>
            <% if trend.percent_meaningful? %>(<%= trend.percent_formatted %>)<% end %>
          </span>
        </div>
      <% end %>
    </div>

    <% holdings = investment_statement.top_holdings(limit: 3) %>
    <% if holdings.any? %>
      <div class="bg-container-inset rounded-xl p-1 space-y-1">
        <% holdings.each do |holding| %>
          <div class="flex items-center justify-between gap-3 px-3 py-2">
            <div class="flex items-center gap-3 min-w-0">
              <% if holding.security.logo_url.present? %>
                <img src="<%= holding.security.logo_url %>" alt="<%= holding.ticker %>" class="w-7 h-7 rounded-full">
              <% else %>
                <div class="w-7 h-7 rounded-full bg-container flex items-center justify-center text-xs font-medium text-secondary">
                  <%= holding.ticker.to_s.first(2).presence || "—" %>
                </div>
              <% end %>
              <span class="text-sm font-medium text-primary truncate"><%= holding.ticker %></span>
            </div>
            <div class="flex items-center gap-3 shrink-0 text-sm">
              <span class="font-medium text-primary privacy-sensitive"><%= format_money(holding.amount_money) %></span>
              <% if holding.trend %>
                <span class="privacy-sensitive w-14 text-right" style="color: <%= holding.trend.color %>"><%= holding.trend.percent_formatted %></span>
              <% else %>
                <span class="text-secondary w-14 text-right">–</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="pt-1 border-t border-tertiary">
      <%= link_to t(".view_all", default: "All investments →"), investment_portfolio_path, class: "text-sm text-secondary hover:text-primary underline", data: { turbo_frame: "_top" } %>
    </div>
  </div>
<% end %>

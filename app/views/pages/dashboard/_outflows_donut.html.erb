<%# locals: (outflows_data:, period:, monthly_spending: nil) %>
<div id="outflows-donut-section" class="@container">
  <div class="px-4">
    <div class="flex justify-between items-center mb-3 gap-2">
      <%# Budget context (absorbed from the old Monthly spending card) %>
      <div class="text-sm min-w-0">
        <% if monthly_spending && monthly_spending[:left].present? %>
          <span class="font-medium text-primary privacy-sensitive"><%= format_money(monthly_spending[:left]) %></span>
          <span class="text-secondary"><%= t(".left_of_budget", budget: format_money(monthly_spending[:budgeted])) %></span>
        <% elsif monthly_spending %>
          <%= link_to t(".set_budget"), budgets_path, class: "text-secondary hover:text-primary underline", data: { turbo_frame: "_top" } %>
        <% end %>
      </div>
      <%= render UI::PeriodPicker.new(
        selected: period,
        url: root_path,
        frame: "dashboard_sections",
        param_name: :outflows_period
      ) %>
    </div>
    <div class="flex flex-col @md:flex-row gap-6 items-center">
      <!-- Donut Chart -->
      <div class="w-full max-w-[200px] @md:w-[176px] @md:shrink-0">
        <div class="h-[176px] relative"
          data-controller="donut-chart"
          data-donut-chart-segments-value="<%= outflows_data[:categories].to_json %>"
          data-donut-chart-segment-opacity-value="0.9"
          data-donut-chart-extended-hover-value="true"
          data-donut-chart-hover-extension-value="3"
          data-donut-chart-enable-click-value="true"
          data-donut-chart-start-date-value="<%= period.date_range.first %>"
          data-donut-chart-end-date-value="<%= period.date_range.last %>">
          <div data-donut-chart-target="chartContainer" class="absolute inset-0 pointer-events-none"></div>

          <div data-donut-chart-target="contentContainer" class="flex justify-center items-center h-full">
            <div data-donut-chart-target="defaultContent" class="flex flex-col items-center">
              <div class="text-secondary text-sm mb-2">
                <span><%= t("pages.dashboard.outflows_donut.total_outflows") %></span>
              </div>

              <div data-donut-chart-target="amount" class="text-xl font-medium text-primary privacy-sensitive whitespace-nowrap">
                <%= format_money Money.new(outflows_data[:total], outflows_data[:currency]) %>
              </div>
            </div>

            <% outflows_data[:categories].each do |category| %>
              <div id="segment_<%= category[:id] %>" class="hidden">
                <div class="flex flex-col gap-2 items-center">
                  <p class="text-sm text-secondary"><%= category[:name] %></p>

                  <p data-donut-chart-target="amount" class="text-xl font-medium text-primary privacy-sensitive whitespace-nowrap">
                    <%= outflows_data[:currency_symbol] %><%= number_with_delimiter(category[:amount], delimiter: ",") %>
                  </p>

                  <p class="text-sm text-secondary privacy-sensitive"><%= category[:percentage] %>%</p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Category List -->
      <div class="w-full @md:flex-1 @md:min-w-0 bg-container-inset rounded-xl p-1 space-y-1 overflow-x-auto">
        <div class="px-4 py-2 flex items-center uppercase text-xs font-medium text-secondary">
          <div class="shrink-0">
            <p class="whitespace-nowrap"><%= t("pages.dashboard.outflows_donut.categories") %><span class="text-subdued mx-1">&middot;</span><%= outflows_data[:categories].count %></p>
          </div>
          <div class="ml-auto text-right flex items-center gap-6">
            <div class="w-16">
              <p><%= t("pages.dashboard.outflows_donut.value") %></p>
            </div>
            <div class="w-16">
              <p><%= t("pages.dashboard.outflows_donut.weight") %></p>
            </div>
          </div>
        </div>
        <%# Top 5 only — the Categories page owns the full list %>
        <% visible_categories = outflows_data[:categories].first(5) %>
        <div class="py-3 shadow-border-xs rounded-lg bg-container font-medium text-sm max-w-full">
          <% visible_categories.each_with_index do |category, idx| %>
            <%
              category_content = capture do
            %>
              <div class="flex items-center gap-3 flex-1 min-w-0">
                <div class="h-7 w-7 flex-shrink-0 group-hover:scale-105 transition-all duration-300 rounded-full flex justify-center items-center"
                  style="
                    background-color: color-mix(in oklab, <%= category[:color] %> 10%, transparent);
                    border-color: color-mix(in oklab, <%= category[:color] %> 10%, transparent);
                    color: <%= category[:color] %>;">
                  <% if category[:icon] %>
                    <%= icon(category[:icon], color: "current", size: "sm") %>
                  <% else %>
                    <%= render DS::FilledIcon.new(
                      variant: :text,
                      hex_color: category[:color],
                      text: category[:name],
                      size: "sm",
                      rounded: true
                    ) %>
                  <% end %>
                </div>
                <span class="text-sm font-medium text-primary truncate"><%= category[:name] %></span>
              </div>
              <div class="flex items-center gap-4 flex-shrink-0 text-right">
                <span class="text-sm font-medium text-primary whitespace-nowrap privacy-sensitive"><%= format_money Money.new(category[:amount], category[:currency]) %></span>
                <span class="text-sm text-secondary whitespace-nowrap w-10 privacy-sensitive"><%= category[:percentage] %>%</span>
              </div>
            <% end %>

            <% if category[:clickable] != false %>
              <%= link_to transactions_path(q: { categories: [category[:name]], start_date: period.date_range.first, end_date: period.date_range.last }),
                  class: "flex items-center justify-between mx-3 px-3 py-2 rounded-lg cursor-pointer group gap-3",
                  data: {
                    turbo_frame: "_top",
                    turbo_prefetch: false,
                    category_id: category[:id],
                    action: "mouseenter->donut-chart#highlightSegment mouseleave->donut-chart#unhighlightSegment"
                  } do %>
                <%= category_content %>
              <% end %>
            <% else %>
              <div class="flex items-center justify-between mx-3 px-3 py-2 rounded-lg group gap-3"
                  data-category-id="<%= category[:id] %>"
                  data-action="mouseenter->donut-chart#highlightSegment mouseleave->donut-chart#unhighlightSegment">
                <%= category_content %>
              </div>
            <% end %>
            <% if idx < visible_categories.size - 1 %>
              <%= render "shared/ruler", classes: "mx-3 @2xl:mx-4" %>
            <% end %>
          <% end %>

          <% if outflows_data[:categories].size > visible_categories.size %>
            <%= render "shared/ruler", classes: "mx-3 @2xl:mx-4" %>
            <%= link_to categories_path,
                class: "flex items-center justify-between mx-3 px-3 py-2 rounded-lg text-sm text-secondary hover:text-primary",
                data: { turbo_frame: "_top" } do %>
              <span><%= t("pages.dashboard.outflows_donut.all_categories", count: outflows_data[:categories].size) %></span>
              <%= icon("arrow-right", size: "sm", color: "current") %>
            <% end %>
          <% end %>
        </div>

        <% if outflows_data[:invested].present? %>
          <%= link_to transactions_path(q: { categories: [outflows_data[:invested][:category_name]], start_date: period.date_range.first, end_date: period.date_range.last }),
              class: "flex items-center justify-between px-4 py-2 text-sm text-secondary hover:text-primary transition-colors",
              data: { turbo_frame: "_top", turbo_prefetch: false } do %>
            <span class="flex items-center gap-2">
              <%= icon("trending-up", size: "sm", color: "current") %>
              <%= t("pages.dashboard.outflows_donut.moved_to_investments") %>
            </span>
            <span class="font-medium privacy-sensitive"><%= format_money Money.new(outflows_data[:invested][:amount], outflows_data[:currency]) %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

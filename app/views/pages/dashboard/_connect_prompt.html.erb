<div class="mb-4 px-4 py-3 rounded-xl bg-container shadow-border-xs flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
  <div class="flex items-center gap-3 grow min-w-0">
    <%= icon("landmark", size: "md", color: "current") %>
    <div class="min-w-0">
      <p class="text-sm font-medium text-primary"><%= t("pages.dashboard.connect_prompt.title") %></p>
      <p class="text-sm text-secondary"><%= t("pages.dashboard.connect_prompt.subtitle") %></p>
    </div>
  </div>
  <div class="flex items-center gap-3 shrink-0">
    <%= render DS::Link.new(
      text: t("pages.dashboard.connect_prompt.cta"),
      variant: "primary",
      icon: "plus",
      href: new_account_path(step: "method_select"),
      frame: :modal
    ) %>
    <%= button_to dismiss_getting_started_path,
          method: :post,
          class: "text-secondary hover:text-primary",
          title: t("pages.dashboard.connect_prompt.dismiss"),
          aria: { label: t("pages.dashboard.connect_prompt.dismiss") } do %>
      <%= icon "x", size: "sm" %>
    <% end %>
  </div>
</div>

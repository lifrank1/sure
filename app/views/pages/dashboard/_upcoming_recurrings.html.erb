<%# locals: (upcoming_recurrings:) %>

<div class="space-y-0.5 px-4">
  <% upcoming_recurrings.each do |recurring| %>
    <% overdue = recurring.next_expected_date < Date.current %>
    <div class="flex items-center justify-between gap-3 px-2 py-2 rounded-lg hover:bg-surface-hover">
      <div class="min-w-0 grow">
        <p class="text-sm text-primary truncate"><%= recurring.name.presence || recurring.merchant&.name || t(".unnamed", default: "Recurring charge") %></p>
        <p class="text-xs <%= overdue ? "text-red-500" : "text-secondary" %>">
          <%= overdue ? t(".overdue", default: "Overdue") : recurring.next_expected_date.strftime("%b %-d") %>
        </p>
      </div>
      <span class="privacy-sensitive text-sm font-medium text-primary shrink-0">
        <%= Money.new(recurring.amount.abs, recurring.currency).format %>
      </span>
    </div>
  <% end %>

  <div class="px-2 pt-3 mt-1 border-t border-tertiary">
    <%= link_to t(".view_all", default: "All recurring →"), recurring_transactions_path, class: "text-sm text-secondary hover:text-primary underline" %>
  </div>
</div>

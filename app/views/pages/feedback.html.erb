<%= content_for :page_title, t(".title") %>

<div class="bg-container shadow-border-xs rounded-xl p-4">
  <h2 class="text-lg font-medium text-primary mb-1"><%= t(".heading") %></h2>
  <p class="text-sm text-secondary mb-4">Questions, bug reports, or feature ideas — email and I'll get back to you.</p>
  <div class="flex flex-col md:flex-row gap-4">
    <%= link_to "mailto:lifranksites@gmail.com", class: "w-full md:w-1/3 flex flex-col items-center p-4 border border-alpha-black-25 rounded-xl hover:bg-container-hover" do %>
      <span class="flex items-center justify-center w-8 h-8 mb-2 text-primary"><%= icon("mail") %></span>
      <span class="text-sm font-medium text-primary text-center">lifranksites@gmail.com</span>
    <% end %>
  </div>
</div>

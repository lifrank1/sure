<%# locals: (family:, active_tab:, mobile: false) %>

<%# Operator-only alert: normal users cannot access instance settings, so the
    banner would be noise they can't act on. Rendered outside the cached
    fragment so role-specific content never leaks across users. %>
<% if family.missing_data_provider? && Current.user&.super_admin? %>
  <div class="mb-3">
    <%= render DS::Alert.new(title: t("accounts.sidebar.missing_data"), variant: :warning) do %>
      <p class="text-secondary"><%= t("accounts.sidebar.missing_data_description", product: product_name) %></p>
      <p><%= link_to t("accounts.sidebar.configure_providers"), settings_hosting_path, class: "underline font-medium" %></p>
    <% end %>
  </div>
<% end %>

<% cache account_sidebar_tabs_cache_key(family: family, active_tab: active_tab, mobile: mobile), expires_in: 12.hours do %>
<div id="account-sidebar-tabs">
  <%# Single grouped list (Copilot-style): group headers already express the
      asset/debt distinction, so no All/Assets/Debts tab strip is needed. %>
  <div class="space-y-2">
    <%= render DS::Link.new(
        text: t("accounts.sidebar.new_account"),
        variant: "ghost",
        full_width: true,
        href: new_account_path(step: "method_select"),
        icon: "plus",
        frame: :modal,
        class: "justify-start"
      ) %>

    <div>
      <% family.balance_sheet.account_groups.each do |group| %>
        <%# open: true — balances visible without clicks (Copilot pattern) %>
        <%= render "accounts/accountable_group", account_group: group, mobile: mobile, all_tab: true, open: true %>
      <% end %>
    </div>
  </div>
</div>
<% end %>

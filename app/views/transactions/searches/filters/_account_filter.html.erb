<%# locals: (form:) %>
<div data-controller="list-filter">
  <%= render DS::SearchInput.new(
        variant: :embedded,
        placeholder: t(".filter_accounts"),
        aria_label: t(".filter_accounts"),
        data: {
          list_filter_target: "input",
          action: "input->list-filter#filter"
        }
      ) %>
  <div class="my-2" id="list" data-list-filter-target="list">
    <%# Filter by id, not name — several provider accounts can import with the
        same name ("CREDIT CARD"), and a name filter can't tell them apart %>
    <% Current.user.accessible_accounts.alphabetically.each do |account| %>
      <div class="filterable-item flex items-center gap-2 p-2" data-filter-name="<%= account.display_name %>">
        <%= form.check_box :account_ids,
                           {
                             multiple: true,
                             checked: @q[:account_ids]&.include?(account.id),
                             class: "checkbox checkbox--light"
                           },
                           account.id,
                           nil %>
        <%= form.label :account_ids, account.display_name, value: account.id, class: "text-sm text-primary" %>
      </div>
    <% end %>
  </div>
</div>
